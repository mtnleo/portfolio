---
import { ui } from "../i18n/ui";
import { milestones } from "../data/experience";
---

<section id="experience">
  <h2
    class="font-display text-2xl text-accent"
    data-i18n="work.title"
  >
    {ui.en["work.title"]}
  </h2>
  <ol class="mt-6 border-l border-border space-y-10 pl-6">
    {
      milestones.map((m, idx) => (
        <li class="relative">
          <span
            class="absolute -left-[31px] top-2 w-3 h-3 rounded-full bg-accent ring-4 ring-bg"
            aria-hidden="true"
          />
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
            <h3 class="font-display text-lg">
              <strong data-i18n-dyn={`exp.${idx}.role`}>{m.role.en}</strong>
              <span class="text-text-muted"> — {m.company}</span>
            </h3>
            <p class="font-mono text-xs text-text-muted sm:whitespace-nowrap">
              {m.start} – {m.end}
            </p>
          </div>
          <ul class="mt-3 space-y-1.5 text-text-muted">
            {m.bullets.en.map((b, j) => (
              <li class="flex gap-2">
                <span class="text-accent select-none" aria-hidden="true">
                  —
                </span>
                <span data-i18n-dyn={`exp.${idx}.bullet.${j}`}>{b}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</section>

<script>
  import { milestones } from "../data/experience";
  type Lang = "en" | "es";
  const root = document.getElementById("experience");
  if (root) {
    const applyLang = (lang: Lang) => {
      root.querySelectorAll<HTMLElement>("[data-i18n-dyn]").forEach((el) => {
        const parts = (el.dataset.i18nDyn ?? "").split(".");
        if (parts[0] !== "exp") return;
        const idx = Number(parts[1]);
        const field = parts[2];
        const m = milestones[idx];
        if (!m) return;
        if (field === "role") {
          el.textContent = m.role[lang];
        } else if (field === "bullet") {
          const j = Number(parts[3]);
          const b = m.bullets[lang]?.[j];
          if (b !== undefined) el.textContent = b;
        }
      });
    };
    new MutationObserver(() =>
      applyLang((document.documentElement.lang || "en") as Lang)
    ).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["lang"],
    });
    applyLang((document.documentElement.lang || "en") as Lang);
  }
</script>
