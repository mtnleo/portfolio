---
import { ui } from "../i18n/ui";

const LINKEDIN_URL = "https://www.linkedin.com/in/martin-leonardi-/";
const GITHUB_URL = "https://github.com/mtnleo";
const EMAIL = "mtnleonardi@gmail.com";
---

<footer class="content-column border-t border-border py-12 sm:py-16">
  <ul class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-sm">
    <li>
      <a
        href={LINKEDIN_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Martin Leonardi on LinkedIn (opens in new tab)"
        class="text-accent-hover hover:text-text transition-colors"
      >
        <span class="link-underline">LinkedIn</span>
        <span aria-hidden="true">↗</span>
      </a>
    </li>
    <li>
      <a
        href={`mailto:${EMAIL}`}
        aria-label={`Email Martin Leonardi at ${EMAIL}`}
        class="text-accent-hover hover:text-text transition-colors"
      >
        <span class="link-underline">Email</span>
        <span aria-hidden="true">↗</span>
      </a>
    </li>
    <li>
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Martin Leonardi on GitHub (opens in new tab)"
        class="text-accent-hover hover:text-text transition-colors"
      >
        <span class="link-underline">GitHub</span>
        <span aria-hidden="true">↗</span>
      </a>
    </li>
  </ul>
  <p class="font-mono text-xs text-text-muted mt-6" data-i18n="footer.note">
    {ui.en["footer.note"]}
  </p>
</footer>
