---
import { ui } from "../i18n/ui";
---

<button
  id="lang-toggle"
  type="button"
  class="font-mono text-sm text-text-muted hover:text-accent-hover link-underline cursor-pointer transition-colors"
  aria-label="Toggle language"
>
  <span data-i18n="toggle.label">{ui.en["toggle.label"]}</span>
</button>

<script>
  import { ui, type Lang } from "../i18n/ui";

  const btn = document.getElementById("lang-toggle");
  if (btn) {
    function applyLang(lang: Lang) {
      const dict = ui[lang];
      document
        .querySelectorAll<HTMLElement>("[data-i18n]")
        .forEach((el) => {
          const key = el.dataset.i18n as keyof typeof dict | undefined;
          if (key && dict[key] !== undefined) {
            el.textContent = dict[key];
          }
        });
      document.documentElement.lang = lang;
      try {
        localStorage.setItem("lang", lang);
      } catch (e) {
        // ignore — storage may be blocked
      }
    }

    // Initial sync: anti-flash script in <head> already set html.lang
    // (saved → navigator.language → "en"). Translate any [data-i18n] on
    // first paint so server-rendered EN flips to the chosen language.
    const initial = (document.documentElement.lang || "en") as Lang;
    if (initial !== "en") applyLang(initial);

    btn.addEventListener("click", () => {
      const current = (document.documentElement.lang || "en") as Lang;
      applyLang(current === "en" ? "es" : "en");
    });
  }
</script>
