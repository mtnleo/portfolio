---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { ui } from "../i18n/ui";

const entries = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

// Pre-render each MDX body (the stack line) so we can place <Content /> below
// the description. Bodies are static HTML — no client JS added.
const projects = await Promise.all(
  entries.map(async (p) => ({
    data: p.data,
    Content: (await render(p)).Content,
  }))
);
---

<section id="projects" class="border-t border-border py-12 sm:py-16">
  <h2
    class="font-display text-2xl text-text"
    data-i18n="projects.title"
  >
    {ui.en["projects.title"]}
  </h2>
  <ul class="mt-6 space-y-12">
    {
      projects.map(({ data, Content }) => (
        <li>
          {data.cover && (
            <a
              href={data.demo ?? data.code ?? "#"}
              class="block overflow-hidden rounded-md bg-bg-elevated"
              target="_blank"
              rel="noopener noreferrer"
            >
              <Image
                src={data.cover}
                alt={data.title}
                widths={[480, 720, 1080]}
                sizes="(min-width: 720px) 680px, 100vw"
                class="w-full project-cover transition-transform duration-500 ease-out"
              />
            </a>
          )}
          <h3 class="font-body text-base font-semibold text-text mt-4">
            {data.title}
          </h3>
          <p
            class="text-text-muted mt-2"
            data-i18n-dyn-desc
            data-desc-en={data.description}
            data-desc-es={data.description_es ?? data.description}
          >
            {data.description}
          </p>
          <div class="project-stack mt-2">
            <Content />
          </div>
          <p class="mt-3 flex gap-5 font-mono text-sm">
            {data.demo ? (
              <a
                href={data.demo}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${data.title} — live demo (opens in new tab)`}
                class="text-accent-hover hover:text-text transition-colors"
              >
                <span class="link-underline" data-i18n="projects.demo">
                  {ui.en["projects.demo"]}
                </span>{" "}
                <span aria-hidden="true">↗</span>
              </a>
            ) : data.demoSoon ? (
              <span class="text-text-muted/60" data-i18n="projects.demoSoon">
                {ui.en["projects.demoSoon"]}
              </span>
            ) : null}
            {data.code ? (
              <a
                href={data.code}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${data.title} — source code on GitHub (opens in new tab)`}
                class="text-accent-hover hover:text-text transition-colors"
              >
                <span class="link-underline" data-i18n="projects.code">
                  {ui.en["projects.code"]}
                </span>{" "}
                <span aria-hidden="true">↗</span>
              </a>
            ) : null}
          </p>
        </li>
      ))
    }
  </ul>
</section>

<style>
  /* MDX body of each project = the stack line. */
  .project-stack :global(p) {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }
  .project-cover:hover {
    transform: scale(1.02);
  }
  @media (prefers-reduced-motion: reduce) {
    .project-cover {
      transition: none;
    }
    .project-cover:hover {
      transform: none;
    }
  }
</style>

<script>
  type Lang = "en" | "es";
  const root = document.getElementById("projects");
  if (root) {
    const applyLang = (lang: Lang) => {
      root
        .querySelectorAll<HTMLElement>("[data-i18n-dyn-desc]")
        .forEach((el) => {
          const v = lang === "es" ? el.dataset.descEs : el.dataset.descEn;
          if (v !== undefined) el.textContent = v;
        });
    };
    new MutationObserver(() =>
      applyLang((document.documentElement.lang || "en") as Lang)
    ).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["lang"],
    });
    applyLang((document.documentElement.lang || "en") as Lang);
  }
</script>
