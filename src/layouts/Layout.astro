---
import "../styles/fonts.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Martin Leonardi — Full-stack developer",
  description = "Portfolio of Martin Leonardi, full-stack developer.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:title" content="Martín Leonardi — Full-stack developer" />
    <meta property="og:description" content="Building software that works, AI-focused." />
    <meta property="og:image" content={new URL("/og-image.png", Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Martín Leonardi — Full-stack developer, AI-focused. martinleonardi.dev"
    />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Martín Leonardi" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Martín Leonardi — Full-stack developer" />
    <meta
      name="twitter:description"
      content="Building software that works, AI-focused."
    />
    <meta name="twitter:image" content={new URL("/og-image.png", Astro.site)} />
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem("lang");
          const lang =
            saved ||
            (navigator.language && navigator.language.startsWith("es")
              ? "es"
              : "en");
          document.documentElement.lang = lang;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
