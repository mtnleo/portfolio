---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import { ui } from "../i18n/ui";
---

<Layout>
  <span id="top"></span>
  <Nav />
  <main class="content-column pt-16 pb-24 space-y-16">
    <Hero />
    <About />
  </main>
  <footer class="content-column pb-12">
    <p class="font-mono text-xs text-text-muted" data-i18n="footer.note">
      {ui.en["footer.note"]}
    </p>
  </footer>
</Layout>
